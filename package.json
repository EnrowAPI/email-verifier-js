{
  "name": "email-verifier",
  "version": "1.0.0",
  "description": "Verify email addresses for deliverability with deterministic verification. Powered by Enrow.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "email-verifier",
    "email-verification",
    "verify-email",
    "email-validation",
    "email-checker",
    "deliverability",
    "catch-all",
    "b2b",
    "enrow"
  ],
  "author": "Enrow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enrow/email-verifier-js"
  },
  "homepage": "https://enrow.io",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
